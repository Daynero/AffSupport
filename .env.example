# Public browser configuration. Copy this file to .env and fill values from
# Supabase Dashboard. Never use a secret/service_role key in any VITE_* value.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SITE_URL=http://127.0.0.1:5173

# Optional development hint only. Database membership in admin_users is the
# sole authorization source for /admin.
VITE_ADMIN_EMAIL=

# Required before a public legal launch; placeholders remain visible otherwise.
VITE_PRODUCT_OPERATOR=
VITE_LEGAL_CONTACT_EMAIL=

# Wishly Agent stays on the existing protected loopback API.
VITE_AGENT_URL=http://127.0.0.1:43120

# The versioned Agent download URL is derived from packages/shared/src/release.ts.
# Agent build. Must exactly match the final Pages origin and the
# PRODUCTION_SITE_ORIGIN constant in packages/shared/src/release.ts
# (release checks enforce that config/production.env stays in sync).
PUBLIC_SITE_ORIGIN=https://wishly-app.pages.dev
DEV_SITE_ORIGIN=http://127.0.0.1:5173
AGENT_PORT=43120
