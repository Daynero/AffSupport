# Web build (Cloudflare Pages)
VITE_AGENT_URL=http://127.0.0.1:43120
# The versioned download URL is derived from packages/shared/src/release.ts.
# Agent build. Must exactly match the final Pages origin and the
# PRODUCTION_SITE_ORIGIN constant in packages/shared/src/release.ts
# (release checks enforce that config/production.env stays in sync).
PUBLIC_SITE_ORIGIN=https://wishly-app.pages.dev
DEV_SITE_ORIGIN=http://127.0.0.1:5173
AGENT_PORT=43120
